# Sunucu
PORT=3001
NODE_ENV=development

# MongoDB — varsayılan yerel; Atlas kullanırken bu satırı Atlas connection string ile değiştirin.
MONGODB_URI=mongodb://127.0.0.1:27017/estate-agency
# Atlas örneği:
# MONGODB_URI=mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/estate-agency?retryWrites=true&w=majority

# İleride JWT auth (Aşama 11)
# JWT_SECRET=change-me-in-production
