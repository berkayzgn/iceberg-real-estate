MONGODB_URI=

# JWT (production'da güçlü ve benzersiz bir JWT_SECRET kullanın)
JWT_SECRET=
# Token ömrü saniye cinsinden (varsayılan 7 gün = 604800)
JWT_EXPIRES_SECONDS=604800

# İlk çalıştırmada oluşturulacak panel kullanıcısı (MongoDB'de yoksa seed edilir)
ADMIN_EMAIL=admin@icebergestate.com
ADMIN_PASSWORD=admin1234

# Virgülle ayrılmış CORS origin listesi (Vercel domain(ler)inizi ekleyin)
# Örnek: https://iceberg-real-estate.vercel.app,https://iceberg-real-estate-git-main-xxx.vercel.app
# Sadece dev için bilerek boş bırakabilirsiniz; backend o zaman local Nuxt portlarını (3000/3001) kabul eder.
CORS_ORIGINS=

PORT=3002

NODE_ENV=development

