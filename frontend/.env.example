# Nest API (global prefix /api) — backend PORT ile uyumlu
NUXT_PUBLIC_API_BASE=http://localhost:3002/api

# Vercel production:
#   `NUXT_PUBLIC_API_BASE=https://<render-app>.onrender.com/api`
